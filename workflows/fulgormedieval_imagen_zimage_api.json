{
  "1": {
    "inputs": {
      "unet_name": "z_image_turbo_bf16.safetensors",
      "weight_dtype": "default"
    },
    "class_type": "UNETLoader",
    "_meta": { "title": "Modelo de difusion: Z-Image Turbo" }
  },
  "2": {
    "inputs": {
      "shift": 3.0,
      "model": ["1", 0]
    },
    "class_type": "ModelSamplingAuraFlow",
    "_meta": { "title": "Muestreo AuraFlow (shift 3)" }
  },
  "3": {
    "inputs": {
      "clip_name": "qwen_3_4b.safetensors",
      "type": "lumina2",
      "device": "default"
    },
    "class_type": "CLIPLoader",
    "_meta": { "title": "Text encoder: Qwen3-4B" }
  },
  "4": {
    "inputs": {
      "text": "PROMPT_AQUI",
      "clip": ["3", 0]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Prompt positivo" }
  },
  "5": {
    "inputs": {
      "conditioning": ["4", 0]
    },
    "class_type": "ConditioningZeroOut",
    "_meta": { "title": "Negativo vacio (modelo turbo, cfg 1)" }
  },
  "6": {
    "inputs": {
      "width": 1280,
      "height": 720,
      "batch_size": 1
    },
    "class_type": "EmptySD3LatentImage",
    "_meta": { "title": "Latente 1280x720" }
  },
  "7": {
    "inputs": {
      "seed": 42,
      "steps": 9,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["2", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["6", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "KSampler (turbo: 9 pasos, cfg 1)" }
  },
  "8": {
    "inputs": {
      "vae_name": "ae.safetensors"
    },
    "class_type": "VAELoader",
    "_meta": { "title": "VAE Flux" }
  },
  "9": {
    "inputs": {
      "samples": ["7", 0],
      "vae": ["8", 0]
    },
    "class_type": "VAEDecode",
    "_meta": { "title": "Decodificar imagen" }
  },
  "10": {
    "inputs": {
      "filename_prefix": "fulgormedieval/keyframes/keyframe",
      "images": ["9", 0]
    },
    "class_type": "SaveImage",
    "_meta": { "title": "Guardar keyframe" }
  }
}
